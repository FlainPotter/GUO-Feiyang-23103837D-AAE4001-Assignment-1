<?xml version="1.0"?>
<launch>
  <arg name="bag_path" default="/mnt/c/Users/User/Desktop/2026-02-02-17-57-27.bag"/>
  <arg name="image_topic" default="/hikcamera/image_2/compressed"/>

  <node pkg="rosbag"
        type="play"
        name="bag_player"
        output="screen"
        args="$(arg bag_path) --clock" />

  <node pkg="aae4011_vehicle_detection"
        type="vehicle_detector_node.py"
        name="vehicle_detector"
        output="screen">
    <param name="image_topic" value="$(arg image_topic)" />
    <param name="conf_threshold" value="0.3" />
    <param name="model" value="yolov8n.pt" />
  </node>
</launch>